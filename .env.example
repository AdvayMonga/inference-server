# Server
HOST=0.0.0.0
PORT=8000

# Batching
MAX_BATCH_SIZE=32
BATCH_TIMEOUT_MS=50.0
MAX_QUEUE_SIZE=1000

# Model
MODEL_NAME=google/gemma-4-E2B-it
BACKEND=mps  # "mps", "cuda", or "cpu"
MAX_TOKENS=512
CONTEXT_WINDOW=8192

# KV Cache
KV_CACHE_MEMORY_FRACTION=0.9

# Streaming
STREAM_BY_DEFAULT=false

# Observability
LOG_LEVEL=INFO
METRICS_PORT=9090
