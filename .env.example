# Server
HOST=0.0.0.0
PORT=8000

# Batching
MAX_BATCH_SIZE=32
BATCH_TIMEOUT_MS=50.0
MAX_QUEUE_SIZE=1000
MAX_ACTIVE_KV_TOKENS=0  # 0 = unbounded; cap on (prompt+max_tokens) summed across in-flight rows
PREFILL_CHUNK_SIZE=0    # 0 = monolithic prefill; 256 is a reasonable starting value

# Model
MODEL_NAME=google/gemma-4-E2B-it
DEVICE=auto  # "auto", "cuda", "mps", or "cpu"
MAX_TOKENS=512
CONTEXT_WINDOW=8192

# KV Cache
KV_CACHE_MEMORY_FRACTION=0.9
KV_CACHE_BLOCK_SIZE=16
KV_CACHE_NUM_BLOCKS=256
EVICTION_POLICY=lru  # "lru", "attention_sink_lru", "h2o"

# Streaming
STREAM_BY_DEFAULT=false

# Single-user optimization
KEEP_MODEL_WARM=true
COMPILE_MODEL=false

# Observability
LOG_LEVEL=INFO
METRICS_PORT=9090

# Reserved for multi-user extension (ignored for now)
MAX_CONCURRENT_SESSIONS=1
PER_SESSION_MEMORY_LIMIT_MB=0
SCHEDULING_POLICY=fcfs  # "fcfs" or "fair"
